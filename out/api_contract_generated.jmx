                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="script">import groovy.json.JsonSlurper

def __getByPath(def obj, String jsonPath) {
  if (obj == null) return null
  if (jsonPath == null) return null
  def p = jsonPath.trim()
  if (!p.startsWith('$.')) return null
  // On utilise /\./ pour dire &quot;le caractère point littéral&quot; en Groovy
  def parts = p.substring(2).split(/\./)
  def cur = obj
  for (def part : parts) {
    if (cur == null) return null
    if (cur instanceof Map) {
      cur = cur.get(part)
    } else {
      return null
    }
  }
  return cur
}

def s = prev.getResponseDataAsString()
assert s != null &amp;&amp; s.trim().length() &gt; 0 : 'Empty response body'
def json = new JsonSlurper().parseText(s)

def array_services = __getByPath(json, '$.services')
assert array_services instanceof List : 'Field $.services should be an array'

// Validate each item in $.services
if (array_services.size() &gt; 0) {
  array_services.eachWithIndex { item, idx -&gt;
    if (item.containsKey('properties') &amp;&amp; item['properties'] != null) {
      assert item['properties'] instanceof Map : '$.services[' + idx + '].properties should be object, got ' + item['properties'].getClass().getName()
    }
    if (item.containsKey('id') &amp;&amp; item['id'] != null) {
      assert item['id'] instanceof String : '$.services[' + idx + '].id should be string, got ' + item['id'].getClass().getName()
    }
  }
}
</stringProp>
