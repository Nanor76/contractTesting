  "paths": {
    "/api/v1/Environments/{id}": {
      "post": {
        "tags": [
          "Url management - Administrators"
        ],
        "summary": "Create or update an environment.",
        "description": "\nThis endpoint allows for the creation or updating of an environment.\n             If the environment with the specified identifier exists, it will be replaced with the provided details.\n             If it does not exist, a new environment will be created.\n             The identifiers provided in the URL are stored in the database as they are. In the event of an update, the case of the identifier may change, which may have an impact on consumers.\n             The endpoint requires authentication and is accessible to role Administrator.\n             It provides detailed error responses for unauthorized and forbidden scenarios.\n\nSample request:\n```\nPOST /api/v1/environments/{id}\n{\n  name: \"My environment\"\n}\n            \nOR\n            \nPOST /api/v1/environments/{id}\n{\n  name: \"My environment\",\n  services: [\n    \"service1\" :[\n       \"url\" : \"https://service1.sample.azure.com\",\n       \"enabled\" : \"true\"\n     ],\n  ]\n}\n             \n```",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The identifier of the environment to create or update.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Body of the environment.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpsertEnvironmentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Environment successfull returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Environment"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden access",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Url management - Administrators"
        ],
        "summary": "Delete an environment.",
        "description": "\nThis endpoint deletes an environment identified by its unique ID.\n            If the environment is successfully deleted, an HTTP status code of 204 is returned.\n            The endpoint requires authentication and is accessible to role Administrator.\n            It provides detailed error responses for unauthorized and forbidden scenarios.\n\nSample request:\n```\nDELETE /api/v1/environments/{id}\naccept: application/json\n            \n```",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The identifier of the environment to delete.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No content",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpStatusCode"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden access",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Url management - Readers"
        ],
        "summary": "Retrieves an environment by its identifier.",
        "description": "\nThis endpoint retrieves the details of a specific environment identified by its unique ID.\n            It returns the environment data if found, otherwise appropriate HTTP status codes are returned.\n            The endpoint requires authentication and is accessible to roles Reader or Writer or Administrator.\n            It provides detailed error responses for unauthorized, forbidden and not found scenarios.\n\nSample request:\n```\nGET /api/v1/environments/{id}\naccept: application/json\n            \n```",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The identifier of the environment to retrieve.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Environment successfull returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Environment"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized access",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden access",
